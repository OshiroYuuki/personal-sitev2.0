---
import { getCollection } from "astro:content";
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import ArrowCard from "@components/ArrowCard.astro";
import Link from "@components/Link.astro";
import { dateRange } from "@lib/utils";
import { SITE, HOME, SOCIALS } from "@consts";

const blog = (await getCollection("blog"))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0,SITE.NUM_POSTS_ON_HOMEPAGE);

const projects = (await getCollection("projects"))
  .filter(project => !project.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0,SITE.NUM_PROJECTS_ON_HOMEPAGE);

const allwork = (await getCollection("work"))
  .sort((a, b) => new Date(b.data.dateStart).valueOf() - new Date(a.data.dateStart).valueOf())
  .slice(0,SITE.NUM_WORKS_ON_HOMEPAGE);

const work = await Promise.all(
  allwork.map(async (item) => {
    const { Content } = await item.render();
    return { ...item, Content };
  })
);

---

<PageLayout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <!-- Bingata (琉球紅型) inspired color strip — bold Okinawan palette -->
    <div class="animate mb-10 flex h-1.5 rounded-full overflow-hidden gap-0.5">
      <div class="flex-1 bg-oki-ocean"></div>
      <div class="flex-1 bg-oki-green"></div>
      <div class="flex-1 bg-oki-gold"></div>
      <div class="flex-1 bg-oki-coral"></div>
      <div class="flex-1 bg-oki-hibiscus"></div>
    </div>
    <h4 class="animate text-3xl font-semibold bg-gradient-to-r from-oki-ocean via-oki-hibiscus to-oki-coral bg-clip-text text-transparent dark:from-oki-ocean-light dark:via-oki-hibiscus dark:to-oki-coral-light">
      Hello I am Oshiro Yuuki!! <span class="not-italic bg-none text-oki-indigo dark:text-oki-cream" style="background:none;-webkit-text-fill-color:unset;">👋🏻</span>
    </h4>
    <div class="space-y-16">
      <section>
        <article class="space-y-4">
          <p class="animate">
            I am an engineer and student researcher at Waseda University's Kasahara-Kimura Lab.
            Right now, I am focusing my energy on mapping the future of financial privacy and
            secure digital sovereignty by bridging the most recent developments in Trusted Execution
            Environments (TEEs), Zero-Knowledge Proofs (ZKPs), and decentralized network architectures
            in order to help create a better future for all. I don't optimize systems to chase
            get-rich-quick trends; I love to break things down to their absolute fundamentals to
            understand how to rebuild them so that I too can help to create a fairer, more
            adversarial-resistant world for all.
          </p>
          <h4 class="animate text-xl font-semibold text-oki-ocean dark:text-oki-ocean-light">
            More about me!
          </h4>
          <p class="animate">
            (WIP) My recent research at Waseda University's Kasahara-Kimura Lab focuses on profiling
            performance overheads and trust boundaries within VM-based TEEs like Intel TDX and
            AMD SEV-SNP. I translate these low-level hardware primitives into defensive Web3
            infrastructure, architecting hybrid protocols that combine secure enclaves with
            Zero-Knowledge Proofs (Circom and SP1-zkVM) to shield everyday users from predatory
            MEV stalking bots and enable private zkTLS data attestations. This drive to master
            data at its lowest execution layer is rooted in a deep-seated curiosity that began
            with developing secure optimization passes for the LLVM compiler toolchain and
            analyzing microarchitecture side-channel vulnerabilities.
          </p>
          <p class="animate">
            (WIP) This obsession with engineering complex, resilient architectures carries directly into
            my role as a startup co-founder and Tech Lead, where I design the distributed node
            communication networks and high-throughput telemetry pipelines required to coordinate
            autonomous underwater vehicle fleets. Coming from a small island ecosystem, I view
            education as an immense privilege and an end in itself; I hack, build, and
            reverse-engineer not for external metrics, but for a pure passion to understand how
            things work. Ultimately, I construct tools for adversarial environments to return data
            sovereignty back to individuals, with the singular goal that my work might inspire
            someone else to sink their teeth into a hard problem.
          </p>
        </article>
      </section>

      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h5 class="text-xl font-semibold text-oki-ocean dark:text-oki-ocean-light">
            Latest posts
          </h5>
          <Link href="/blog">
            See all posts
          </Link>
        </div>
        <ul class="flex flex-col gap-4">
          {blog.map(post => (
            <li>
              <ArrowCard entry={post} />
            </li>
          ))}
        </ul>
      </section>

      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h5 class="text-xl font-semibold text-oki-ocean dark:text-oki-ocean-light">
            Work Experience
          </h5>
          <Link href="/work">
            See all work
          </Link>
        </div>
        <ul class="flex flex-col space-y-4">
          {work.map(entry => (
            <li>
              <div class="text-sm text-oki-gold/80 dark:text-oki-gold">
                {dateRange(entry.data.dateStart, entry.data.dateEnd)}
              </div>
              <div class="font-semibold text-oki-coral dark:text-oki-coral-light">
                {entry.data.company}
              </div>
              <div class="text-sm opacity-75">
                {entry.data.role}
              </div>
              <article>
                <entry.Content />
              </article>
            </li>
          ))}
        </ul>
      </section>

      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h5 class="text-xl font-semibold text-oki-ocean dark:text-oki-ocean-light">
            Recent projects
          </h5>
          <Link href="/projects">
            See all projects
          </Link>
        </div>
        <ul class="flex flex-col gap-4">
          {projects.map(project => (
            <li>
              <ArrowCard entry={project} />
            </li>
          ))}
        </ul>
      </section>

      <section class="animate space-y-4">
        <h5 class="text-xl font-semibold text-oki-ocean dark:text-oki-ocean-light">
          Let's Connect
        </h5>
        <article>
          <p>
            If you want to get in touch with me about something or just to say hi,
            reach out on social media or send me an email.
          </p>
        </article>
        <ul class="flex flex-wrap gap-2">
          {SOCIALS.map(SOCIAL => (
            <li class="flex gap-x-2 text-nowrap">
              <Link href={SOCIAL.HREF} external aria-label={`${SITE.NAME} on ${SOCIAL.NAME}`}>
                {SOCIAL.NAME}
              </Link>
              {"/"}
            </li>
          ))}
          <li class="line-clamp-1">
            <Link href={`mailto:${SITE.EMAIL}`} aria-label={`Email ${SITE.NAME}`}>
              {SITE.EMAIL}
            </Link>
          </li>
        </ul>
      </section>
    </div>
  </Container>
</PageLayout>
