---
import { cn } from "@lib/utils";

type Props = {
  href: string;
  external?: boolean;
  underline?: boolean;
}

const { href, external, underline = true, ...rest } = Astro.props;
---

<a 
  href={href} 
  target={ external ? "_blank" : "_self" } 
  class={cn("inline-block decoration-oki-ocean/25 dark:decoration-oki-ocean-light/30 hover:decoration-oki-ocean/50 hover:dark:decoration-oki-ocean-light/55 text-current hover:text-oki-ocean hover:dark:text-oki-ocean-light transition-colors duration-300 ease-in-out", underline && "underline underline-offset-2")}
  {...rest}>
  <slot/>
</a>
