---
import type { CollectionEntry } from "astro:content";

type Props = {
  entry: CollectionEntry<"blog"> | CollectionEntry<"projects">;
}

const { entry } = Astro.props;

const series  = entry.collection === "blog"     ? entry.data.series  : undefined;
const tags    = entry.collection === "projects" ? entry.data.tags    : undefined;
const repoURL = entry.collection === "projects" ? entry.data.repoURL : undefined;

const tagColors: Record<string, string> = {
  PATS: "bg-oki-ocean/15 text-oki-ocean dark:bg-oki-ocean/20 dark:text-oki-ocean-light border border-oki-ocean/30",
  demo: "bg-oki-gold/15 text-oki-gold dark:bg-oki-gold/20 dark:text-oki-gold border border-oki-gold/30",
  WIP:  "bg-oki-coral/15 text-oki-coral dark:bg-oki-coral/20 dark:text-oki-coral-light border border-oki-coral/30",
};
const defaultTagColor = "bg-oki-hibiscus/15 text-oki-hibiscus dark:bg-oki-hibiscus/20 dark:text-oki-hibiscus border border-oki-hibiscus/30";

const seriesColors: Record<string, string> = {
  PATS: "bg-oki-ocean/15 text-oki-ocean dark:bg-oki-ocean/20 dark:text-oki-ocean-light border border-oki-ocean/30",
  demo: "bg-oki-gold/15 text-oki-gold dark:bg-oki-gold/20 dark:text-oki-gold border border-oki-gold/30",
};
const defaultSeriesColor = "bg-oki-hibiscus/15 text-oki-hibiscus dark:bg-oki-hibiscus/20 dark:text-oki-hibiscus border border-oki-hibiscus/30";
---

<div class="arrow-card relative group flex flex-nowrap py-3 px-4 pr-10 rounded-lg border border-oki-ocean/25 dark:border-oki-ocean-light/20 hover:bg-oki-ocean/6 dark:hover:bg-oki-ocean-light/8 hover:text-oki-ocean dark:hover:text-oki-ocean-light transition-colors duration-300 ease-in-out">

  <!-- Stretched invisible link — covers the whole card for navigation -->
  <a href={`/${entry.collection}/${entry.slug}`}
     class="absolute inset-0 rounded-lg z-0"
     aria-label={entry.data.title}></a>

  <!-- Content sits above the stretched link -->
  <div class="relative z-10 flex flex-col flex-1 min-w-0 pointer-events-none">
    <div class="font-semibold truncate">
      {entry.data.title}
    </div>
    <div class="text-sm desc">
      <span>{entry.data.description}</span>
      <div class="desc-footer">

        {/* Blog: series badge */}
        {series && (
          <span class={`inline-block px-2 py-0.5 rounded-full text-xs font-medium ${seriesColors[series] ?? defaultSeriesColor}`}>
            {series}
          </span>
        )}

        {/* Project: tag badges */}
        {tags?.map(tag => (
          <span class={`inline-block px-2 py-0.5 rounded-full text-xs font-medium ${tagColors[tag] ?? defaultTagColor}`}>
            {tag}
          </span>
        ))}

        {/* Project: GitHub link — real <a> tag, sits above stretched nav link via z-10 */}
        {repoURL && (
          <a href={repoURL}
             target="_blank"
             rel="noopener noreferrer"
             class="relative z-10 inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-[#1a1a1a] text-white border border-black/30 hover:bg-black transition-colors duration-150">
            <svg class="size-3 shrink-0" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
            </svg>
            GitHub
          </a>
        )}

      </div>
    </div>
  </div>

  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    class="absolute z-10 top-1/2 right-2 -translate-y-1/2 size-5 stroke-2 fill-none stroke-current">
    <line x1="5" y1="12" x2="19" y2="12" class="translate-x-3 group-hover:translate-x-0 scale-x-0 group-hover:scale-x-100 transition-transform duration-300 ease-in-out" />
    <polyline points="12 5 19 12 12 19" class="-translate-x-1 group-hover:translate-x-0 transition-transform duration-300 ease-in-out" />
  </svg>
</div>

<style>
  .desc {
    max-height: 1.35em;
    overflow: hidden;
    transition: max-height 0.25s cubic-bezier(0.4, 0, 0.2, 1) 0s;
  }
  .arrow-card:hover .desc {
    max-height: 8rem;
    transition: max-height 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94) 0.28s;
  }

  .desc-footer {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    align-items: center;
    margin-top: 0.5rem;
    padding-top: 0.4rem;
    border-top: 1px solid rgba(0, 146, 163, 0.2);
    min-height: 1.75rem;
    opacity: 0;
    pointer-events: auto;
    transition: opacity 0.2s ease 0s;
  }
  .arrow-card:hover .desc-footer {
    opacity: 1;
    transition: opacity 0.2s ease 0.38s;
  }
</style>
